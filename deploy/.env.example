SITE_DOMAIN=shellshock.dns-dynamic.net
INSTANCE_TERMS_ACCEPTED=false

SERVER_HOST=0.0.0.0
SERVER_PORT=30010
SHUTDOWN_TIMEOUT_SECONDS=15
ALLOWED_ORIGINS=https://shellshock.dns-dynamic.net
DB_PATH=/data/disaster-alert.fjall

# Generate independently with: openssl rand 32 | base64 | tr '+/' '-_' | tr -d '=\n'
DATA_ENCRYPTION_KEY=replace-with-32-byte-base64url-key
ALERT_SIGNING_KEY=replace-with-a-different-32-byte-base64url-key
ALERT_DETAIL_BASE_URL=https://shellshock.dns-dynamic.net

BARK_SOUND=alarm
BARK_VOLUME=10
BARK_GROUP=灾害预警
BARK_CALL=true

WOLFX_WEBSOCKET_URL=wss://ws-api.wolfx.jp/all_eew
FANSTUDIO_WEBSOCKET_URL=wss://ws.fanstudio.tech/all
RECONNECT_MIN_SECONDS=1
RECONNECT_MAX_SECONDS=30
PUSH_UPDATES=false
UPDATE_MIN_REPORT_GAP=1
IGNORE_TRAINING=true
IGNORE_CANCEL=false
STALE_ORIGIN_SECONDS=600

P_WAVE_KM_S=6.0
S_WAVE_KM_S=3.5
REVERSE_GEOCODING_ENABLED=true
REVERSE_GEOCODING_URL=https://nominatim.openstreetmap.org/reverse
