eew.example.com {
    encode zstd gzip
    root * /opt/earthquake-alert/web

    # Run the backend with SERVER_HOST=127.0.0.1 for this deployment, or block port 30010 at the firewall.

    handle /api/* {
        reverse_proxy 127.0.0.1:30010
    }

    handle /health {
        reverse_proxy 127.0.0.1:30010
    }

    handle {
        try_files {path} /index.html
        file_server
    }
}
